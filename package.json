{
  "name": "final-approach",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Final Approach — ATC core-loop prototype. Real-time-with-pause air traffic control feel test.",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "sim:test": "esbuild tools/headless.ts --bundle --platform=node --format=esm | node --input-type=module",
    "smoke": "esbuild tools/smoke-dom.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test": "npm run typecheck && npm run sim:test && npm run smoke"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
